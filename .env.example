# Groq API - Agent AI de călătorie (GRATUIT, 14,400 req/zi)
# Obtine gratuit la: https://console.groq.com → API Keys
# Model folosit: llama-3.1-8b-instant (rapid + gratuit)
GROQ_API_KEY=your_groq_api_key_here

# Kiwi.com / Tequila API (zbor live + virtual interlining)
# Obtine gratuit la: https://tequila.kiwi.com/
KIWI_API_KEY=your_kiwi_api_key_here

# Travelpayouts affiliate token (comision 3% bilete Kiwi, Booking etc.)
# Obtine la: https://www.travelpayouts.com/
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token_here

# Booking.com Affiliate ID (comision 4% cazari)
# Obtine la: https://www.booking.com/affiliate-program
BOOKING_AFFILIATE_ID=your_booking_affiliate_id_here

# Email SMTP pentru alerte (ex: Gmail App Password, Resend, SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Email destinatar alerte
ALERT_EMAIL=your_email@gmail.com

# Secret pentru protejarea API routes (genereaza un string random)
API_SECRET=change_this_to_a_random_secret_string
